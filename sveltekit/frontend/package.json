		"trailbase": "^0.10.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.0",
