# TrailBase backend URL
TRAILBASE_URL=http://localhost:4000

# Encryption secret for API keys stored in the database
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=your-encryption-secret-here

# Public app URL (used for OpenRouter API referer header)
# In production, set this to your domain
PUBLIC_APP_URL=http://localhost:5173

# Optional: Fallback API keys (users can also configure these in Settings)
# YOUTUBE_API_KEY=""
# RAPIDAPI_KEY=""
# OPENROUTER_API_KEY=""
