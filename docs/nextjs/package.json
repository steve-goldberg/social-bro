{
  "name": "social-bro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "unset DATABASE_URL; next dev --turbopack 2>&1 | grep --line-buffered -v 'baseline-browser-mapping'",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -- prisma generate",
    "db:migrate": "dotenv -- prisma migrate dev",
    "db:push": "dotenv -- prisma db push",
    "db:studio": "dotenv -- prisma studio",
    "db:seed": "dotenv -- npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@tanstack/react-table": "^8.21.3",
    "bcrypt": "^6.0.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "jose": "^6.1.3",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.555.0",
    "next": "16.0.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sonner": "^2.0.7",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.3",
    "prisma": "^7.0.1",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.1"
  }
}
